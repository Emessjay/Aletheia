# Aletheia FastAPI server — local environment template.
# Copy to .env and edit as needed. The .env file is gitignored.

# Postgres (phase 2). The local docker-compose.yml service uses these creds.
# On Railway, set DATABASE_URL via the linked Supabase Postgres plugin.
DATABASE_URL=postgresql://aletheia:aletheia@localhost:5432/aletheia

# Source SQLite for the one-shot ingest. Defaults to the repo's data/
# directory if unset.
# ALETHEIA_CORPUS_PATH=/absolute/path/to/Aletheia.sqlite

# Audio cache (server-py downloads MP3s on demand). Railway's filesystem is
# ephemeral; locally /tmp is fine.
# ALETHEIA_AUDIO_CACHE=/tmp/aletheia-audio

# Static frontend dir served by FastAPI. Defaults to ./dist locally and
# /app/public in the Docker image.
# ALETHEIA_STATIC_DIR=/absolute/path/to/dist
