# Aletheia FastAPI server — local environment template.
# Copy to .env and edit as needed. The .env file is gitignored.

# Postgres (phase 2). The local docker-compose.yml service uses these creds.
# On Railway, set DATABASE_URL via the linked Supabase Postgres plugin.
DATABASE_URL=postgresql://aletheia:aletheia@localhost:5432/aletheia

# Source SQLite for the one-shot ingest. Defaults to the repo's data/
# directory if unset.
# ALETHEIA_CORPUS_PATH=/absolute/path/to/Aletheia.sqlite

# Audio cache (server-py downloads MP3s on demand). Railway's filesystem is
# ephemeral; locally /tmp is fine.
# ALETHEIA_AUDIO_CACHE=/tmp/aletheia-audio

# Static frontend dir served by FastAPI. Defaults to ./dist locally and
# /app/public in the Docker image.
# ALETHEIA_STATIC_DIR=/absolute/path/to/dist

# Supabase JWT verification (phase 3a). Server-side use only — verify
# end-user JWTs presented as `Authorization: Bearer <jwt>` on /api/user/*.
# The frontend uses the anon public key (added in phase 3b), not this.
#
# Current Supabase projects sign tokens with ES256; the server fetches the
# public key from {SUPABASE_URL or VITE_SUPABASE_URL}/auth/v1/.well-known/
# jwks.json at boot, so no secret needs configuring for those. The legacy
# HS256 shared secret below is still honored (and is what the test suite
# signs with) — find it at Settings → API → JWT Settings → JWT Secret.
# If neither is available, the server still boots and /api/health +
# /api/corpus work, but /api/user/* returns 503 "auth not configured".
# SUPABASE_JWT_SECRET=
# SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase project URL + anon (publishable) key — read by the React build
# at `import.meta.env.VITE_SUPABASE_URL` / `VITE_SUPABASE_ANON_KEY`. These
# are shipped in the browser bundle, so use the *anon* key, never the
# service-role key. If either is unset the web build still boots but auth
# is disabled (reader works anonymously; sign-in surfaces return
# "auth not configured" at call time).
# VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOi...
