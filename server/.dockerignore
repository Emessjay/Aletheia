# Build-context exclusions for `docker build -f server/Dockerfile .`
#
# Keep this list aggressive: every byte that lands in the build context is
# uploaded to the Docker daemon (or to Railway's remote builder), and any
# pre-built artifact under node_modules/ or target/ will be re-built inside
# the image anyway.

node_modules
server/node_modules
server/dist
dist
dist-ssr
.vite
tsconfig.tsbuildinfo

# Rust / Tauri — not used by the web build at all.
src-tauri/target
src-tauri/gen
src-tauri

# Ingest pipeline build outputs.
tools/ingest/.build
tools/ingest/.swiftpm
tools/**/__pycache__
tools/**/.venv

# Raw corpus sources — the compiled SQLite is the only thing the runtime
# needs, and bundling the multi-GB sources would explode build time.
data/sources

# Worktrees created by scripts/new-worktree.sh sit as siblings of the repo,
# so they shouldn't end up in the context, but be defensive.
../aletheia-*

# Auditor system state — sibling-of-repo; same reasoning.
.auditor-state

# Logs / OS junk.
*.log
.DS_Store
.git
.github
.vscode
.idea

# Audio cache (if a dev ran the server locally and populated /tmp shadows).
audio
